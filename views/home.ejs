<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <div class="bg-shape bg-shape-one"></div>
  <div class="bg-shape bg-shape-two"></div>

  <main class="layout">
    <section class="hero">
      <div class="hero-copy-block">
        <p class="eyebrow">Centro de control de inventario</p>
        <h1>Gestion de productos</h1>
        <div class="hero-actions">
          <a class="primary-link" href="#product-form">Registrar producto</a>
          <button id="focus-table" class="ghost-button" type="button">Ver inventario</button>
        </div>
      </div>

      <aside class="summary-panel">
        <div class="summary-card summary-card-main">
          <span class="summary-label">Productos registrados</span>
          <strong id="product-count">0</strong>
        </div>

        <div class="summary-grid">
          <div class="summary-card">
            <span class="summary-label">Categorias</span>
            <strong><%= categorias.length %></strong>
          </div>
          <div class="summary-card">
            <span class="summary-label">Estado</span>
            <strong id="inventory-status">Sincronizando</strong>
          </div>
        </div>
      </aside>
    </section>

    <section class="panel-grid">
      <article class="panel form-panel">
        <div class="panel-heading">
          <div>
            <p class="section-tag">Formulario</p>
            <h2 id="form-title">Registrar producto</h2>
          </div>
          <button id="cancel-edit" class="ghost-button hidden" type="button">Cancelar edicion</button>
        </div>

        <form id="product-form">
          <input id="product-id" type="hidden" />

          <label for="nombre">Nombre</label>
          <input id="nombre" name="nombre" type="text" placeholder="Ej. Laptop Gamer" required />

          <label for="descripcion">Descripcion</label>
          <textarea id="descripcion" name="descripcion" rows="4" placeholder="Describe el producto" required></textarea>

          <div class="form-row">
            <div>
              <label for="precio">Precio</label>
              <input id="precio" name="precio" type="number" min="0" step="0.01" placeholder="0.00" required />
            </div>
            <div>
              <label for="stock">Stock</label>
              <input id="stock" name="stock" type="number" min="0" step="1" placeholder="0" required />
            </div>
          </div>

          <label for="categoria">Categoria</label>
          <select id="categoria" name="categoria" required>
            <option value="">Selecciona una categoria</option>
            <% categorias.forEach((categoria) => { %>
              <option value="<%= categoria %>"><%= categoria %></option>
            <% }) %>
          </select>

          <button class="primary-button" type="submit">Guardar producto</button>
        </form>

        <div id="feedback" class="feedback" aria-live="polite"></div>
      </article>

      <article class="panel table-panel" id="inventory-section">
        <div class="panel-heading">
          <div>
            <p class="section-tag">Inventario</p>
            <h2>Listado de productos</h2>
          </div>
          <button id="refresh-products" class="ghost-button" type="button">Actualizar lista</button>
        </div>

        <div class="table-wrapper">
          <table>
            <thead>
              <tr>
                <th>Nombre</th>
                <th>Descripcion</th>
                <th>Precio</th>
                <th>Stock</th>
                <th>Categoria</th>
                <th>Acciones</th>
              </tr>
            </thead>
            <tbody id="products-table-body">
              <tr>
                <td colspan="6" class="empty-state">Cargando productos...</td>
              </tr>
            </tbody>
          </table>
        </div>
      </article>
    </section>
  </main>

  <script src="/app.js"></script>
</body>
</html>
